<!-- ===== SECTION 5: Differentiator ===== -->
<section id="section5" class="section sec-diff" data-bg="#fff">
    <div class="container">
        <div class="diff-layout-v2">
            <!-- LEFT: Title + Physics Tags -->
            <div class="diff-left-v2 reveal-left">
                <span class="section-label">Expertise</span>
                <h2 class="section-title">
                    왜 <span class="highlight">피오랩스</span>인가
                </h2>
                <p class="sub-desc">
                    단순한 마케팅 대행이 아닙니다.<br>
                    병원 경영의 모든 과정을 함께 설계하는 <strong>성장 파트너</strong>입니다.
                </p>
                <div id="physics-container" class="physics-container">
